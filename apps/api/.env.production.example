# Database
DATABASE_URL=postgresql://timechamp:PASSWORD@localhost:6432/timechamp

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=<minimum-32-chars-random-string>
JWT_REFRESH_SECRET=<minimum-32-chars-random-string>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App URLs
APP_URL=https://app.timechamp.io
API_URL=https://api.timechamp.io
NEXT_PUBLIC_API_URL=https://api.timechamp.io/api/v1

# Stripe (optional at launch)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_PRO=price_...

# Backblaze B2 Storage (use this instead of S3_BUCKET for zero-egress cost)
B2_BUCKET=timechamp-prod
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=<your-b2-key-id>
B2_APP_KEY=<your-b2-application-key>
B2_CDN_URL=https://cdn.timechamp.io

# Streaming
STREAMING_ENABLED=true
WS_CORS_ORIGIN=https://app.timechamp.io
DAILY_BW_CAP_MB=500
SESSION_MAX_HOURS=8

# Server
PORT=3001
NODE_ENV=production
